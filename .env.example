# 服务配置
PORT=3000
NODE_ENV=development

# 微信公众号（测试号）配置
# appID 和 appsecret 由平台提供，在测试号管理页面查看
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
# Token 由你自定义（任意字符串），需与测试号后台「接口配置信息」中填写的 Token 保持一致
WECHAT_TOKEN=your_wechat_token

# 消息转发目标（可选）
FORWARD_URL=https://your-forward-endpoint.com/webhook

# 调用 POST /wechat/send 接口时需在 X-Callback-Token 请求头中携带此值
# 未配置时 /wechat/send 端点不可用，建议设置为随机长字符串
CALLBACK_TOKEN=your_callback_token
